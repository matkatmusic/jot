{
  "name": "tmux_lib.py: prepend tmux_ to 8 underscore-prefixed funcs",
  "_notes": [
    "Skipped: '_tmux_session_exists' (already _tmux_-prefixed); all 32 public 'tmux_*' funcs (already prefixed).",
    "'_default_tmux_runner' / '_run_tmux' / '_default_tmux_send': drop the embedded 'tmux' token, prepend '_tmux_'."
  ],
  "mapping": [
    {"old": "_default_tmux_runner",  "new": "_tmux_default_runner"},
    {"old": "_default_tmux_send",    "new": "_tmux_default_send"},
    {"old": "_run_tmux",             "new": "_tmux_run"},
    {"old": "_backgroundKill",       "new": "_tmux_backgroundKill"},
    {"old": "_live_pane_ids",        "new": "_tmux_live_pane_ids"},
    {"old": "_kill_pane",            "new": "_tmux_kill_pane"},
    {"old": "_paneCurrentCommand",   "new": "_tmux_paneCurrentCommand"},
    {"old": "_listLivePaneIds",      "new": "_tmux_listLivePaneIds"}
  ],
  "targets": [
    "common/scripts/tmux_lib.py",
    "common/scripts/jot_lib.py",
    "common/scripts/debate_lib.py",
    "common/scripts/plate_dispatcher.py",
    "tests/test_tmux_create.py",
    "tests/test_debate_locks.py",
    "tests/test_debate_capacity.py"
  ]
}

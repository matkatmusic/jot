{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}scripts/jot_plugin_orchestrator.py"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ \"$PLATE_SKIP_AUTO\" = \"1\" ] && exit 0; jq '. + {prompt: \"/plate\"}' | python3 ${CLAUDE_PLUGIN_ROOT}scripts/jot_plugin_orchestrator.py"
          }
        ]
      }
    ]
  }
}


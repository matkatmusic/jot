{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}scripts/jot-plugin-orchestrator.sh"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ \"$PLATE_SKIP_AUTO\" = \"1\" ] && exit 0; jq '. + {prompt: \"/plate\"}' | bash ${CLAUDE_PLUGIN_ROOT}scripts/jot-plugin-orchestrator.sh"
          }
        ]
      }
    ]
  }
}


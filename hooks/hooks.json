{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/orchestrator.sh"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "jq '. + {prompt: \"/plate\"}' | bash ${CLAUDE_PLUGIN_ROOT}/scripts/orchestrator.sh"
          }
        ]
      }
    ]
  }
}

